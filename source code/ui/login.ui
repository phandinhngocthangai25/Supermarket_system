     <string notr="true">/* Áp dụng cho các ô nhập liệu */
QLineEdit {
    background-color: #2b2b2b;
    border: 1px solid #555555;
    border-radius: 6px; /* Bo góc mềm mại */
    padding: 6px 10px;
    color: #ffffff;
}

/* Hiệu ứng khi người dùng click vào ô nhập */
QLineEdit:focus {
    border: 1px solid #00a8ff; /* Viền sáng lên màu xanh khi chọn */
}

/* Áp dụng cho nút Đăng Nhập */
QPushButton {
    background-color: #00a8ff; /* Đổi nút thành màu xanh nổi bật */
    color: white;
    border-radius: 6px;
    padding: 8px;
    font-weight: bold;
}

/* Hiệu ứng khi di chuột vào nút */
QPushButton:hover {
    background-color: #008cd1;
}</string>
