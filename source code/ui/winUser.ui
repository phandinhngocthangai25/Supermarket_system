   <property name="styleSheet">
    <string notr="true">/* ---- TOÀN BỘ CỬA SỔ ---- */
QMainWindow {
    background-color: #121212; /* Nền tối tổng thể */
}

/* ---- THANH SIDEBAR BÊN TRÁI ---- */
QFrame#frameSidebar {
    background-color: #1e1e1e; /* Màu nền Sidebar sáng hơn nền chính một chút */
    border-right: 1px solid #2d2d2d; /* Đường chia cắt dọc mờ */
}

/* ---- CÁC NÚT BẤM TRÊN SIDEBAR ---- */
QFrame#frameSidebar QPushButton {
    background-color: transparent; /* Xóa nền xám thô của nút mặc định */
    color: #b3b3b3; /* Màu chữ xám nhẹ */
    border: none; /* Xóa viền nút */
    border-radius: 6px; /* Bo góc nhẹ cho nút */
    text-align: left; /* Căn chữ sang bên trái */
    padding-left: 15px; /* Đẩy chữ cách mép trái ra một chút */
    height: 42px; /* Cố định chiều cao các nút cho đều nhau */
    font-size: 13px;
    font-weight: bold;
}

/* Hiệu ứng khi rê chuột vào các nút menu */
QFrame#frameSidebar QPushButton:hover {
    background-color: #2a2a2a; /* Nền sáng lên */
    color: #ffffff; /* Chữ chuyển sang màu trắng */
}

/* Hiệu ứng riêng dành cho nút Đăng Xuất nằm dưới cùng */
QFrame#frameSidebar QPushButton#btnDangXuat {
    color: #ff5555; /* Chữ màu đỏ để cảnh báo */
}
QFrame#frameSidebar QPushButton#btnDangXuat:hover {
    background-color: #3a1a1a; /* Nền đỏ tối khi hover */
    color: #ff6e6e;
}

/* ---- VÙNG NỘI DUNG BÊN PHẢI ---- */
QStackedWidget#stackedContent {
    background-color: #181818; /* Nền của vùng hiển thị nội dung */
    border-radius: 8px;
}</string>
